{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run CDK LSP Client",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}", "${workspaceFolder}/examples/cdk-lsp-test"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"]
    }
  ]
}
